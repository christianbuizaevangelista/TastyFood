// Tasty Food Manufacturing Inc. — Distribution Management System
// Prisma schema: multi-tier distribution hierarchy with RBAC, inventory,
// purchase orders, POS sales, approvals and KPI tracking.

generator client {
  provider      = "prisma-client-js"
  // "native" for local dev; the rhel targets are for Vercel's serverless runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase Supavisor, port 6543) for the app at runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by Prisma for migrations / db push.
  // For local Docker Postgres, set DIRECT_URL to the same value as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrgType {
  PRINCIPAL
  PROVINCIAL
  CITY
  RESELLER
}

enum OrgStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  PRINCIPAL
  PROVINCIAL
  CITY
  RESELLER
}

enum DistributionType {
  TRADE
  DROP_SHIP
}

enum PoStatus {
  DRAFT
  SUBMITTED
  APPROVED
  FULFILLED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SaleChannel {
  PO
  POS
}

// How a purchase order is paid. MANA = the in-system credits wallet (1 PHP = 1 Mana).
enum PaymentMethod {
  CASH
  MANA
}

enum ApprovalType {
  ORG_ONBOARDING
  PO_APPROVAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Geographic clustering for territories.
//  REGION (cluster) > PROVINCE (Provincial Distributor) >
//  CITY/Municipality (City Distributor) > BARANGAY (Reseller)
enum TerritoryLevel {
  REGION
  PROVINCE
  CITY
  BARANGAY
}

// Confidential account paperwork the Principal keeps on file per distributor.
enum OrgDocumentType {
  VALID_ID
  AGREEMENT
  APPLICATION_FORM
  OTHER
}

// ---------------------------------------------------------------------------
// Accounting (double-entry) — finance department only, separate from the DMS.
// ---------------------------------------------------------------------------

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

// How movements in a (non-cash) account are classified on the Cash Flow Statement.
enum CashflowSection {
  OPERATING
  INVESTING
  FINANCING
}

// ---------------------------------------------------------------------------
// Core entities
// ---------------------------------------------------------------------------

model Organization {
  id           String    @id @default(cuid())
  name         String
  type         OrgType
  // Each tier purchases from exactly one level above it.
  parentId     String?
  parent       Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children     Organization[] @relation("OrgHierarchy")

  // Discount off SRP this org receives when it BUYS from its parent.
  // PRINCIPAL 0, PROVINCIAL 0.20, CITY 0.15, RESELLER 0.08
  discountRate Float     @default(0)

  // Market segment for downstream accounts: RESELLER (Provincial→City→Reseller
  // hierarchy) or RETAIL (a retail distributor with no downline).
  segment      String    @default("RESELLER")

  // Onboarding/approval state.
  status       OrgStatus @default(PENDING)
  // Membership activation (independent of approval; can be toggled later).
  isActive     Boolean   @default(true)
  // When set, the account is removed from CRM/structure but its records remain.
  archivedAt   DateTime?

  // CRM / contact details.
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  notes        String?

  // KPI target (revenue) for the current period.
  salesTarget  Float     @default(0)

  // "Mana" credits wallet (1 PHP = 1 Mana). Used to pre-pay purchase orders.
  manaBalance  Float     @default(0)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  users        User[]
  inventory    Inventory[]
  ledger       StockLedger[]

  poAsBuyer    PurchaseOrder[] @relation("PoBuyer")
  poAsSeller   PurchaseOrder[] @relation("PoSeller")

  salesAsSeller Sale[] @relation("SaleSeller")
  salesAsBuyer  Sale[] @relation("SaleBuyer")

  approvalsForOrg Approval[] @relation("ApprovalSubject")
  kpiRecords    KPIRecord[]

  // The geographic territory this org occupies (if assigned).
  territory     Territory? @relation("OrgTerritory")

  manaPurchases ManaPurchase[]
  manaTxns      ManaTxn[]
  customers     Customer[] @relation("OrgCustomers")

  documents     OrgDocument[]
  referralsSent     Referral[] @relation("ReferralFrom")
  referralsReceived Referral[] @relation("ReferralTo")
  journalEntries    JournalEntry[] @relation("EntryDistributor")
  distributorPayments DistributorPayment[]

  @@index([parentId])
  @@index([type])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  // null until an invited staff sets their password
  name         String
  role         UserRole
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  isActive     Boolean  @default(true)
  // The org's owner has full control; staff users get specific permissions.
  isOwner      Boolean  @default(false)
  permissions  String[] @default([])
  // Invite flow for staff to set their own password.
  inviteToken   String?  @unique
  inviteExpires DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdPOs   PurchaseOrder[] @relation("PoCreatedBy")
  createdSales Sale[]          @relation("SaleCreatedBy")
  requestedApprovals Approval[] @relation("ApprovalRequester")
  decidedApprovals   Approval[] @relation("ApprovalDecider")
  uploadedAttachments PoAttachment[] @relation("AttachmentUploader")

  @@index([orgId])
}

model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  category    String?
  // Size of this SKU (e.g. "200g"). Each size is its own product with its own SKU & SRP.
  size        String?
  // Suggested Retail Price — the basis for all tier (reseller-channel) pricing.
  srp         Float
  // Separate SRP for the RETAIL distribution channel (falls back to `srp` if unset).
  retailSrp   Float?
  // Optional per-product tier discount overrides (fractions, e.g. 0.15). When set,
  // they replace the standard tier discount FOR THIS PRODUCT ONLY (e.g. institutional
  // pricing). Null = use the standard TIER_DISCOUNT for that tier.
  provincialDiscount Float?
  cityDiscount       Float?
  resellerDiscount   Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory   Inventory[]
  ledger      StockLedger[]
  poItems     PurchaseOrderItem[]
  saleItems   SaleItem[]
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

model Inventory {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id])
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int      @default(0)
  // Unit cost set by the distributor (optional).
  cost         Float?
  // Critical/reorder level — blank by default; the distributor sets it.
  reorderLevel Int?
  // Debounce for the low-stock email (set when notified, cleared on restock).
  lowStockNotifiedAt DateTime?
  updatedAt    DateTime @updatedAt

  @@unique([orgId, productId])
  @@index([orgId])
}

// Append-only per-SKU stock ledger for auditability.
model StockLedger {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  change    Int      // +in / -out
  balance   Int      // resulting balance after this movement
  reason    String   // e.g. PO_RECEIVED, PO_FULFILLED, POS_SALE, ADJUSTMENT
  refType   String?  // PurchaseOrder | Sale | Adjustment
  refId     String?
  createdAt DateTime @default(now())

  @@index([orgId, productId])
}

// ---------------------------------------------------------------------------
// Purchase Orders (buyer orders from immediate parent)
// ---------------------------------------------------------------------------

model PurchaseOrder {
  id               String   @id @default(cuid())
  number           String   @unique
  buyerOrgId       String
  buyerOrg         Organization @relation("PoBuyer", fields: [buyerOrgId], references: [id])
  sellerOrgId      String
  sellerOrg        Organization @relation("PoSeller", fields: [sellerOrgId], references: [id])
  distributionType DistributionType @default(TRADE)
  status           PoStatus @default(DRAFT)

  discountRate     Float    // buyer tier discount applied to the whole PO
  subtotal         Float    @default(0) // sum of line SRP * qty
  total            Float    @default(0) // sum of discounted line totals

  // Payment method; MANA transfers credits from buyer to seller on approval.
  paymentMethod    PaymentMethod @default(CASH)

  // Optional free-text note from the buyer.
  note             String?

  // Shipping tracking link set by the Principal for drop-ship orders.
  trackingLink     String?

  // Buyer's target/expected delivery date (optional).
  expectedDeliveryDate DateTime?

  // Drop-ship delivery details (end recipient the Principal ships to directly).
  recipientName    String?
  recipientAddress String?
  recipientPhone   String?
  landmark         String?

  createdById      String
  createdBy        User     @relation("PoCreatedBy", fields: [createdById], references: [id])

  submittedAt      DateTime?
  approvedAt       DateTime?
  fulfilledAt      DateTime?
  receivedAt       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            PurchaseOrderItem[]
  approvals        Approval[] @relation("ApprovalPO")
  sale             Sale?      @relation("SaleFromPO")
  attachments      PoAttachment[]

  @@index([buyerOrgId])
  @@index([sellerOrgId])
  @@index([status])
}

// Buyer-uploaded files attached to a PO (e.g. proof of payment), visible to
// the buyer and its supplier. Stored as base64 to keep setup serverless-simple.
model PoAttachment {
  id           String   @id @default(cuid())
  poId         String
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  kind         String   @default("PROOF_OF_PAYMENT")
  fileName     String
  mimeType     String
  size         Int
  data         String   // base64-encoded file content
  uploadedById String
  uploadedBy   User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([poId])
}

model PurchaseOrderItem {
  id        String   @id @default(cuid())
  poId      String
  po        PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  // Cumulative quantity actually received by the buyer (supports partial receipts).
  receivedQuantity Int @default(0)
  unitSrp   Float    // SRP at time of order
  unitPrice Float    // discounted unit price
  lineTotal Float    // unitPrice * quantity

  @@index([poId])
}

// ---------------------------------------------------------------------------
// Sales (POS direct sales, or the recorded sale generated from a PO)
// ---------------------------------------------------------------------------

model Sale {
  id               String   @id @default(cuid())
  number           String   @unique
  sellerOrgId      String
  sellerOrg        Organization @relation("SaleSeller", fields: [sellerOrgId], references: [id])
  // Optional downstream org buyer (if selling to a known account).
  buyerOrgId       String?
  buyerOrg         Organization? @relation("SaleBuyer", fields: [buyerOrgId], references: [id])
  channel          SaleChannel @default(POS)
  distributionType DistributionType @default(TRADE)

  customerName     String?  // walk-in / end customer for POS
  // Optional link to a saved end-customer (captures who a reseller supplies).
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  discountRate     Float    @default(0)
  subtotal         Float    @default(0)
  total            Float    @default(0)

  // Payment terms for a POS sale to a distributor: true = on account (Accounts
  // Receivable), false = cash. Drives the finance posting + per-distributor A/R.
  onAccount        Boolean  @default(false)
  // When an on-account sale is expected to be paid (for the A/R aging report).
  dueDate          DateTime?

  // If this sale was generated from a fulfilled PO.
  poId             String?  @unique
  po               PurchaseOrder? @relation("SaleFromPO", fields: [poId], references: [id])

  createdById      String
  createdBy        User     @relation("SaleCreatedBy", fields: [createdById], references: [id])

  createdAt        DateTime @default(now())

  items            SaleItem[]

  @@index([sellerOrgId])
  @@index([channel])
  @@index([distributionType])
  @@index([createdAt])
}

// A payment received from a distributor against their Accounts Receivable balance.
model DistributorPayment {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id])
  amount      Float
  date        DateTime
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  @@index([orgId])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  refundedQuantity Int @default(0)
  unitSrp   Float
  unitPrice Float
  lineTotal Float

  @@index([saleId])
}

// ---------------------------------------------------------------------------
// Approvals (org onboarding + PO approval)
// ---------------------------------------------------------------------------

model Approval {
  id            String   @id @default(cuid())
  type          ApprovalType
  status        ApprovalStatus @default(PENDING)

  // Subject org (the org being onboarded/approved).
  orgId         String
  org           Organization @relation("ApprovalSubject", fields: [orgId], references: [id])

  // Optional PO subject (for PO_APPROVAL).
  poId          String?
  po            PurchaseOrder? @relation("ApprovalPO", fields: [poId], references: [id])

  requestedById String?
  requestedBy   User?    @relation("ApprovalRequester", fields: [requestedById], references: [id])
  decidedById   String?
  decidedBy     User?    @relation("ApprovalDecider", fields: [decidedById], references: [id])
  decidedAt     DateTime?
  note          String?

  createdAt     DateTime @default(now())

  @@index([orgId])
  @@index([status])
  @@index([type])
}

// ---------------------------------------------------------------------------
// KPI snapshots (per org, per period)
// ---------------------------------------------------------------------------

// A geographic node in the distribution territory tree. A territory below the
// REGION level can be assigned to exactly one organization (its distributor);
// an unassigned assignable territory is "vacant".
model Territory {
  id            String   @id @default(cuid())
  name          String
  level         TerritoryLevel
  parentId      String?
  parent        Territory?  @relation("TerritoryTree", fields: [parentId], references: [id])
  children      Territory[] @relation("TerritoryTree")
  assignedOrgId String?  @unique
  assignedOrg   Organization? @relation("OrgTerritory", fields: [assignedOrgId], references: [id])
  createdAt     DateTime @default(now())

  @@index([parentId])
  @@index([level])
}

// An end-customer that a distributor (usually a Reseller) supplies. Captures
// the last-mile customer database. Visible up the chain for the owner's parents.
model Customer {
  id          String   @id @default(cuid())
  name        String
  type        String?  // Sub-Reseller | Retail | Bakery | Consumer
  phone       String?
  address     String?
  note        String?
  ownerOrgId  String   // the org that serves this customer (e.g. the Reseller)
  ownerOrg    Organization @relation("OrgCustomers", fields: [ownerOrgId], references: [id])
  createdById String
  createdAt   DateTime @default(now())
  sales       Sale[]

  @@index([ownerOrgId])
}

// A downloadable material (catalog, price list, poster, etc.) the Principal
// uploads for distributors to download. File stored inline as base64.
model Material {
  id           String   @id @default(cuid())
  title        String
  description  String?
  fileName     String
  mimeType     String
  size         Int
  data         String   // base64 (no data: prefix)
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// A request to buy Mana credits, with proof of payment, approved by the Principal.
model ManaPurchase {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id])
  amount        Float
  status        ApprovalStatus @default(PENDING)
  fileName      String
  mimeType      String
  size          Int
  data          String   // base64 proof of payment
  requestedById String?
  decidedById   String?
  decidedAt     DateTime?
  note          String?
  createdAt     DateTime @default(now())

  @@index([orgId])
  @@index([status])
}

// Append-only ledger of Mana movements per org.
model ManaTxn {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  change    Float
  balance   Float
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())

  @@index([orgId])
}

// Confidential paperwork (Valid ID, signed agreement, application form, …) the
// Principal uploads against a distributor/reseller account. Visible ONLY to the
// Principal and its staff — never to the account itself. Stored inline as base64.
model OrgDocument {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type         OrgDocumentType @default(OTHER)
  fileName     String
  mimeType     String
  size         Int
  data         String   // base64-encoded file content
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([orgId])
}

// A lead/customer the Principal refers down to a distributor or reseller. The
// recipient org is notified by email and can see it in their Referrals page.
model Referral {
  id          String   @id @default(cuid())
  fromOrgId   String   // the Principal making the referral
  fromOrg     Organization @relation("ReferralFrom", fields: [fromOrgId], references: [id])
  toOrgId     String   // the distributor/reseller the lead is referred to
  toOrg       Organization @relation("ReferralTo", fields: [toOrgId], references: [id])
  name        String
  address     String
  cpNumber    String
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  @@index([toOrgId])
  @@index([fromOrgId])
}

// A line in the chart of accounts. Company-wide (the Principal's books).
model Account {
  id              String  @id @default(cuid())
  code            String  @unique
  name            String
  type            AccountType
  // Optional parent for sub-accounts (chart-of-accounts hierarchy).
  parentId        String?
  parent          Account?  @relation("AccountTree", fields: [parentId], references: [id])
  children        Account[] @relation("AccountTree")
  // Cash & cash equivalents — these accounts ARE the cash on the cash-flow statement.
  isCash          Boolean @default(false)
  // For non-cash accounts: which section a cash movement against it belongs to.
  cashflowSection CashflowSection?
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())

  lines           JournalLine[]

  @@index([type])
}

// A balanced double-entry journal entry (sum of debits == sum of credits).
model JournalEntry {
  id          String  @id @default(cuid())
  number      String  @unique
  date        DateTime
  memo        String?
  reference   String?
  createdById String
  createdAt   DateTime @default(now())

  // Optional: ties an entry to a distributor delivery (A/R sale on account).
  distributorOrgId  String?
  distributorOrg    Organization? @relation("EntryDistributor", fields: [distributorOrgId], references: [id])
  deliveryReceiptNo String?

  // When auto-generated from an operations event (a POS/PO sale), links back to it
  // and guarantees a single posting. Manual entries leave these null.
  sourceType String?
  sourceId   String?

  lines       JournalLine[]
  attachments JournalAttachment[]
  items       JournalItem[]

  @@unique([sourceType, sourceId])
  @@index([date])
}

// Per-SKU line of a distributor delivery recorded in a journal entry.
model JournalItem {
  id        String  @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  productId String?
  sku       String
  name      String
  quantity  Int
  unitPrice Float
  amount    Float

  @@index([entryId])
}

model JournalLine {
  id        String  @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId String
  account   Account @relation(fields: [accountId], references: [id])
  debit     Float   @default(0)
  credit    Float   @default(0)
  memo      String?

  @@index([entryId])
  @@index([accountId])
}

// Receipts / supporting documents attached to a journal entry (e.g. expense receipts).
model JournalAttachment {
  id           String  @id @default(cuid())
  entryId      String
  entry        JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  fileName     String
  mimeType     String
  size         Int
  data         String   // base64-encoded file content
  uploadedById String
  createdAt    DateTime @default(now())

  @@index([entryId])
}

model KPIRecord {
  id                String   @id @default(cuid())
  orgId             String
  org               Organization @relation(fields: [orgId], references: [id])
  periodStart       DateTime
  periodEnd         DateTime
  salesVolume       Int      @default(0)   // units sold
  revenue           Float    @default(0)
  target            Float    @default(0)
  activeMembers     Int      @default(0)   // active downstream members
  poFulfillmentRate Float    @default(0)   // 0..1
  inventoryTurnover Float    @default(0)
  growthPct         Float    @default(0)   // period-over-period %
  createdAt         DateTime @default(now())

  @@index([orgId])
  @@index([periodStart, periodEnd])
}
