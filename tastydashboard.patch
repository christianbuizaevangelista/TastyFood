-// GET /dashboard — role-aware KPI cards + chart data, scoped to the chain.
+// Percentage change of `current` over `previous` (100% when growing from zero).
+function growthPct(current: number, previous: number): number {
+  if (previous > 0) return round2(((current - previous) / previous) * 100);
+  return current > 0 ? 100 : 0;
+}
+
+// Calendar-month buckets spanning [from, to], including the (possibly partial) end month.
+function monthBuckets(from: Date, to: Date): { label: string; year: number; month: number }[] {
+  const out: { label: string; year: number; month: number }[] = [];
+  let d = new Date(from.getFullYear(), from.getMonth(), 1);
+  const last = new Date(to.getFullYear(), to.getMonth(), 1);
+  while (d <= last) {
+    out.push({
+      label: d.toLocaleString('en-US', { month: 'short', year: '2-digit' }),
+      year: d.getFullYear(),
+      month: d.getMonth(),
+    });
+    d = new Date(d.getFullYear(), d.getMonth() + 1, 1);
+  }
+  return out;
+}
+
