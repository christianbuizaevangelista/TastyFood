+// Up/down percentage pill comparing a value against the previous period.
+export function DeltaChip({ value }: { value: number }) {
+  const up = value > 0;
+  const down = value < 0;
+  const cls = up
+    ? 'bg-green-50 text-green-700'
+    : down
+    ? 'bg-red-50 text-red-700'
+    : 'bg-slate-100 text-slate-500';
+  const arrow = up ? '▲' : down ? '▼' : '–';
+  return (
+    <div className={`mt-1.5 inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-xs font-medium ${cls}`}>
+      <span>{arrow}</span>
+      <span>{Math.abs(value).toFixed(1)}% vs prev</span>
+    </div>
+  );
+}
