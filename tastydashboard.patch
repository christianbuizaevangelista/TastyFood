+// ---------------------------------------------------------------------------
+// Date-range presets + custom picker
+// ---------------------------------------------------------------------------
+
+type Range = { from: string; to: string; preset: string };
+
+function ymd(d: Date): string {
+  const p = (n: number) => String(n).padStart(2, '0');
+  return `${d.getFullYear()}-${p(d.getMonth() + 1)}-${p(d.getDate())}`;
+}
+
+const PRESETS: { key: string; label: string }[] = [
+  { key: 'thisMonth', label: 'This month' },
+  { key: '30d', label: '30D' },
+  { key: '3m', label: '3M' },
+  { key: '6m', label: '6M' },
+  { key: '12m', label: '12M' },
+];
+
+function presetRange(key: string): Range {
+  const now = new Date();
+  const to = ymd(now);
+  let from: Date;
+  switch (key) {
+    case 'thisMonth':
+      from = new Date(now.getFullYear(), now.getMonth(), 1);
+      break;
+    case '30d':
+      from = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 29);
+      break;
+    case '3m':
+      from = new Date(now.getFullYear(), now.getMonth() - 2, 1);
+      break;
+    case '12m':
+      from = new Date(now.getFullYear(), now.getMonth() - 11, 1);
+      break;
+    case '6m':
+    default:
+      from = new Date(now.getFullYear(), now.getMonth() - 5, 1);
+      break;
+  }
+  return { from: ymd(from), to, preset: key };
+}
+
+function PeriodSelector({ range, onChange }: { range: Range; onChange: (r: Range) => void }) {
+  return (
+    <div className="flex flex-wrap items-center gap-2">
+      <div className="flex rounded-lg border border-slate-200 bg-white p-0.5 shadow-sm">
+        {PRESETS.map((p) => (
+          <button
+            key={p.key}
+            onClick={() => onChange(presetRange(p.key))}
+            className={`rounded-md px-2.5 py-1 text-xs font-semibold transition ${
+              range.preset === p.key
+                ? 'bg-brand-500 text-white'
+                : 'text-slate-600 hover:bg-slate-100'
+            }`}
+          >
+            {p.label}
+          </button>
+        ))}
+      </div>
+      <div className="flex items-center gap-1.5">
+        <input
+          type="date"
+          value={range.from}
+          max={range.to}
+          onChange={(e) => onChange({ ...range, from: e.target.value, preset: 'custom' })}
+          className="input w-auto py-1 text-xs"
+        />
+        <span className="text-xs text-slate-400">→</span>
+        <input
+          type="date"
+          value={range.to}
+          min={range.from}
+          onChange={(e) => onChange({ ...range, to: e.target.value, preset: 'custom' })}
+          className="input w-auto py-1 text-xs"
+        />
+      </div>
+    </div>
+  );
+}
